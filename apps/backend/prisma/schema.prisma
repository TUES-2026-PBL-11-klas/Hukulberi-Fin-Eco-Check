generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CITIZEN
  ADMIN
  DISPATCHER
}

model User {
  id          String   @id @default(uuid())
  email       String   @unique
  password    String
  displayName String?
  role        UserRole @default(CITIZEN)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("users")
}
